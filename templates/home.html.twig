{% extends 'base.html.twig' %}

{% block title %}Accueil | Playmate{% endblock %}

{% block body %}
    {% include 'header.html.twig' %}

    <main class="page">
        <div class="container">
            <section class="mb-8">
                <div class="card">
                    <div class="mb-4">
                        <h2 class="section-title">Mes tournois à venir</h2>
                    </div>

                    {% if tournaments is defined and tournaments|length > 0 %}
                        <div class="grid grid-3">
                            {% for tournament in tournaments %}
                                <article class="panel">
                                    <h3 class="mb-2">{{ tournament.name }}</h3>
                                    <p class="text-muted small mb-2">
                                        {{ tournament.game ?? 'Jeu non précisé' }}
                                    </p>
                                    <p class="small mb-1">
                                        <strong>Date :</strong> {{ tournament.date ? tournament.date|date('d/m/Y H:i') : 'À confirmer' }}
                                    </p>
                                    <p class="small mb-0">
                                        <strong>Lieu :</strong> {{ tournament.location ?? 'Lieu non précisé' }}
                                    </p>
                                </article>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted">Aucun tournoi inscrit pour le moment.</p>
                    {% endif %}
                </div>
            </section>

            <div class="grid" style="grid-template-columns: minmax(0, 2fr) minmax(320px, 1fr); align-items: start;">
                <section class="stack-lg">
                    <div class="card">
                        <div class="mb-4">
                            <h2 class="section-title">Actualités</h2>
                        </div>

                        {% if newsArticles is defined and newsArticles|length > 0 %}
                            <div class="stack-lg">
                                {% for article in newsArticles %}
                                    <article class="panel">
                                        <h3 class="mb-2">{{ article.title }}</h3>

                                        {% if article.publishedAt is defined and article.publishedAt %}
                                            <p class="small text-muted mb-2">
                                                Publié le {{ article.publishedAt|date('d/m/Y') }}
                                            </p>
                                        {% endif %}

                                        <p class="mb-4 text-muted">
                                            {{ article.excerpt ?? article.content|slice(0, 180) ~ '...' }}
                                        </p>

                                        {% if article.url is defined and article.url %}
                                            <a href="{{ article.url }}" class="btn btn-secondary">Lire l’article</a>
                                        {% endif %}
                                    </article>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-muted">Aucune actualité disponible.</p>
                        {% endif %}
                    </div>
                </section>

                <aside class="stack-lg">
                    <section class="card">
						<div class="mb-4">
							<h2 class="section-title">Dernières cartes en vente</h2>
						</div>

						{% if latestItems is defined and latestItems|length > 0 %}
							<div id="latest-items-carousel" class="carousel slide" data-bs-interval="false">
								<div class="carousel-inner">
									{% for item in latestItems %}
										{% set image = item.images|length ? item.images[0] : '/images/items/placeholder.jpg' %}

										<div class="carousel-item {% if loop.first %}active{% endif %}">
											<div class="carousel-card-wrap">
												<article class="market-card">
													<div class="market-card__image-wrap">
														<img
															src="{{ asset(image) }}"
															alt="{{ item.name }}"
															class="market-card__image"
														>
													</div>

													<div class="market-card__content">
														<h3 class="market-card__title">{{ item.name }}</h3>
														<p class="market-card__description">{{ item.description }}</p>
														<p class="market-card__price">{{ item.price }} €</p>
													</div>
												</article>
											</div>
										</div>
									{% endfor %}
								</div>

								{% if latestItems|length > 1 %}
									<div class="carousel-nav-row">
										<button
											class="carousel-nav carousel-nav--prev"
											type="button"
											data-bs-target="#latest-items-carousel"
											data-bs-slide="prev"
											aria-label="Carte précédente"
										>
											<span class="carousel-nav__icon" aria-hidden="true">‹</span>
										</button>

										<button
											class="carousel-nav carousel-nav--next"
											type="button"
											data-bs-target="#latest-items-carousel"
											data-bs-slide="next"
											aria-label="Carte suivante"
										>
											<span class="carousel-nav__icon" aria-hidden="true">›</span>
										</button>
									</div>
								{% endif %}
							</div>
						{% else %}
							<p class="text-muted">Aucune carte en vente récemment.</p>
						{% endif %}
					</section>

                    <section class="card">
                        <div class="mb-4">
                            <h2 class="section-title">Calendrier des événements</h2>
                        </div>

                        <div class="calendar-wrapper">
							<div class="calendar-grid">
								{% set days = ['L', 'M', 'M', 'J', 'V', 'S', 'D'] %}
								{% for day in days %}
									<div class="calendar-weekday">{{ day }}</div>
								{% endfor %}

								{% for dayNumber in 1..31 %}
									{% set hasEvent = eventDays is defined and dayNumber in eventDays %}
									{% set isToday = currentDay is defined and dayNumber == currentDay %}

									<div class="
										calendar-day
										{% if hasEvent %} calendar-day--event{% endif %}
										{% if isToday %} calendar-day--today{% endif %}
									">
										{{ dayNumber }}
									</div>
								{% endfor %}
							</div>
						</div>

                        {% if upcomingEvents is defined and upcomingEvents|length > 0 %}
                            <div class="stack mt-4">
                                {% for event in upcomingEvents %}
                                    <article class="panel">
                                        <h3 class="small mb-1">{{ event.title }}</h3>
                                        <p class="small text-muted mb-1">
                                            {{ event.date ? event.date|date('d/m/Y H:i') : 'Date à confirmer' }}
                                        </p>
                                        <p class="small text-muted">
                                            {{ event.location ?? 'Lieu non précisé' }}
                                        </p>
                                    </article>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-muted mt-4">Aucun événement à venir.</p>
                        {% endif %}
                    </section>
                </aside>
            </div>
        </div>
    </main>
{% endblock %}