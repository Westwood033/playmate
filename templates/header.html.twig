                    </a>
                </div>
                <div class="nav nav-pills mx-2  mt-2">
                    <a href="#" class=" without-line {% if app.request.getPathInfo() starts with path('app_home', {id: app.user.id}) %} title text-decoration-underline {% else %}text-body{% endif %}">
