<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js" integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN" crossorigin="anonymous"></script>
<link rel="stylesheet" href="{{ asset('styles/app.css') }}">

<header class="site-header">
    <div class="container">
        <div class="site-header-inner">
            <a href="{{ path('app_home') }}" class="brand">
                <span class="brand-mark">P</span>
                <span class="brand-name">Playmate</span>
            </a>

            {% if app.user %}
                <nav class="nav">
                    {% if 'ROLE_SHOP' in app.user.roles %}
                        <a href="#" class="{% if app.request.getPathInfo() starts with path('app_home', {id: app.user.id}) %}text-body{% else %}text-muted{% endif %}">
                            Ma Boutique
                        </a>
                        <a href="#" class="{% if app.request.getPathInfo() starts with path('app_home', {id: app.user.id}) %}text-body{% else %}text-muted{% endif %}">
                            Mes Tournois
                        </a>
                    {% else %}
                        <a href="{{ path('app_tournament_new', {id: app.user.id}) }}"
                           class="{% if app.request.getPathInfo() starts with path('app_tournament_new', {id: app.user.id}) %}text-body{% else %}text-muted{% endif %}">
                            Créer un tournoi
                        </a>
                    {% endif %}

                    <a href="#" class="text-muted">
                        TCG à l'achat
                    </a>

                    <a href="#" class="btn btn-secondary">
                        Déconnexion
                    </a>
                </nav>
            {% endif %}
        </div>
    </div>
</header>