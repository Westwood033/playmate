{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/item.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/show.css') }}">
{% endblock %}

{% block title %}{{ item.name }} — Playmate{% endblock %}

{% block body %}

    {% set condLabels = {
        'neuf':     'Neuf',
        'tres_bon': 'Très bon état',
        'bon':      'Bon état',
        'correct':  'État correct',
        'pieces':   'Pour pièces'
    } %}

    {% set catLabels = {
        'electronique': 'Électronique',
        'vetements':    'Vêtements',
        'maison':       'Maison',
        'sport':        'Sport',
        'jeux':         'Jeux & Jouets',
        'livres':       'Livres',
        'autre':        'Autre'
    } %}

    <div class="show-page">

        {# ── Fil d'Ariane ── #}
        <nav class="show-breadcrumb">
            <a href="{{ path('item_index') }}">Articles</a>
            <span>›</span>
            {% if item.category %}
                <a href="{{ path('item_index', {category: item.category}) }}">
                    {{ catLabels[item.category] ?? item.category }}
                </a>
                <span>›</span>
            {% endif %}
            <span class="show-breadcrumb__current">{{ item.name }}</span>
        </nav>

        <div class="show-layout">

            {# ══════════════════════════════════════
           COLONNE GAUCHE — Galerie photos
        ══════════════════════════════════════ #}
            <div class="show-gallery">

                {# Image principale #}
                <div class="show-gallery__main" id="gallery-main">
                    {% if item.images|length > 0 %}
                        <img
                                src="{{ asset('uploads/items/' ~ item.images[0]) }}"
                                alt="{{ item.name }}"
                                id="gallery-main-img"
                        >
                    {% else %}
                        <div class="show-gallery__placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="2"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <path d="m21 15-5-5L5 21"/>
                            </svg>
                            <p>Aucune photo</p>
                        </div>
                    {% endif %}

                    {% if item.sold %}
                        <div class="show-gallery__sold-overlay">Vendu</div>
                    {% endif %}
                </div>

                {# Miniatures de navigation #}
                {% if item.images|length > 1 %}
                    <div class="show-gallery__thumbs" id="gallery-thumbs">
                        {% for img in item.images %}
                            <button
                                    type="button"
                                    class="show-gallery__thumb {% if loop.first %}show-gallery__thumb--active{% endif %}"
                                    data-src="{{ asset('uploads/items/' ~ img) }}"
                                    aria-label="Photo {{ loop.index }}"
                            >
                                <img src="{{ asset('uploads/items/' ~ img) }}" alt="Photo {{ loop.index }}">
                            </button>
                        {% endfor %}
                    </div>
                {% endif %}

            </div>

            {# ══════════════════════════════════════
           COLONNE DROITE — Infos + actions
        ══════════════════════════════════════ #}
            <div class="show-info">

                {# Badges catégorie + état #}
                <div class="show-info__badges">
                    {% if item.category %}
                        <span class="badge badge--category">
                        {{ catLabels[item.category] ?? item.category }}
                    </span>
                    {% endif %}
                    {% if item.condition %}
                        <span class="badge badge--condition">
                        {{ condLabels[item.condition] ?? item.condition }}
                    </span>
                    {% endif %}
                    {% if item.sold %}
                        <span class="badge badge--sold">Vendu</span>
                    {% endif %}
                </div>

                <h1 class="show-info__title">{{ item.name }}</h1>

                <p class="show-info__price">
                    {{ item.price|number_format(2, ',', ' ') }} €
                </p>

                {# Description #}
                {% if item.description %}
                    <div class="show-info__description">
                        <h2>Description</h2>
                        <p>{{ item.description|nl2br }}</p>
                    </div>
                {% endif %}

                {# Séparateur #}
                <hr class="show-info__sep">

                {# Vendeur #}
                <div class="show-info__seller">
                    <div class="show-info__seller-avatar">
                        {{ item.owner.username|first|upper }}
                    </div>
                    <div class="show-info__seller-details">
                        <p class="show-info__seller-name">{{ item.owner.username }}</p>
                        <p class="show-info__seller-since">
                            Membre
                            depuis {{ item.owner.createdAt is defined ? item.owner.createdAt|date('M Y') : 'N/A' }}
                        </p>
                    </div>
                </div>

                {# Date de publication #}
                <p class="show-info__date">
                    Publié le {{ item.createdAt|date('d/m/Y à H:i') }}
                </p>

                {# ── Actions ── #}
                <div class="show-info__actions">

                    {% if not item.sold %}
                        {# Bouton contact (à brancher selon ta logique métier) #}
                        <a href="mailto:{{ item.owner.email }}" class="btn-contact">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            </svg>
                            Contacter le vendeur
                        </a>
                    {% endif %}

                    {# Actions propriétaire / admin #}
                    {% if app.user and (app.user == item.owner or is_granted('ROLE_ADMIN')) %}
                        <div class="show-info__owner-actions">
                            <a href="{{ path('item_edit', {id: item.id}) }}" class="btn-edit">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                </svg>
                                Modifier
                            </a>
                        </div>
                    {% endif %}

                </div>

            </div>
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function initGallery() {
            const mainImg = document.getElementById('gallery-main-img');
            const thumbs = document.querySelectorAll('.show-gallery__thumb');

            thumbs.forEach(thumb => {
                const clone = thumb.cloneNode(true);
                thumb.parentNode.replaceChild(clone, thumb);
            });

            document.querySelectorAll('.show-gallery__thumb').forEach(thumb => {
                thumb.addEventListener('click', () => {
                    if (mainImg) {
                        mainImg.src = thumb.dataset.src;
                        mainImg.style.opacity = '0';
                        requestAnimationFrame(() => {
                            mainImg.style.transition = 'opacity 0.2s';
                            mainImg.style.opacity = '1';
                        });
                    }
                    document.querySelectorAll('.show-gallery__thumb')
                        .forEach(t => t.classList.remove('show-gallery__thumb--active'));
                    thumb.classList.add('show-gallery__thumb--active');
                });
            });
        }

        document.addEventListener('turbo:load', initGallery);
        document.addEventListener('DOMContentLoaded', initGallery);
    </script>
{% endblock %}
